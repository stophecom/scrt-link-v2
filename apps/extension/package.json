{
	"name": "@scrt-link/extension",
	"version": "0.0.1",
	"description": "Browser extension to quickly share an encrypted, one-time secret via scrt.link",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"postinstall": "wxt prepare"
	},
	"dependencies": {
		"@scrt-link/client": "workspace:*"
	},
	"devDependencies": {
		"@wxt-dev/module-svelte": "^2.0.5",
		"svelte": "^5.55.7",
		"svelte-check": "^4.1.0",
		"typescript": "^5.7.2",
		"wxt": "^0.20.6"
	}
}
